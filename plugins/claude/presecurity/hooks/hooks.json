{
  "description": "presecurity lightweight scan hook",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/bin/run-presecurity.sh\" --root \"$PWD\" scan >/tmp/presecurity-last-scan.log 2>/tmp/presecurity-last-scan.err || true"
          }
        ]
      }
    ]
  }
}
